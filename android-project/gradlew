##############################################################################
#
#   Gradle start up script for POSIX generated by Gradle.
#
#   Important for running:
#
#   (1) You need a POSIX-compliant shell to run this script. If your /bin/sh is
#       noncompliant, but you have some other compliant shell available, you may
#       specify it by setting the SHELL variable when running this script.
#       Example: SHELL=/bin/bash ./gradlew
#
#   (2) The Java home directory may be supplied via the JAVA_HOME environment
#       variable, which overrides the detected value.
#
#   (3) Alternatively, you can specify the JVM arguments to be used to start
#       the JVM by setting the JVM_OPTS environment variable. Use it like this:
#       JVM_OPTS="-Xmx64m -Xms64m" ./gradlew <some task>
#
#   Gradle uses a wrapper version during download so it can fail for projects
#   that have never been run on the system specified.
#
##############################################################################

# Attempt to set APP_HOME
# Resolve links: $0 may be a symlink
PRG=$0
# Need this for relative symlinks.
while [ -h "$PRG" ]; do
  ls=$(ls -ld "$PRG")
  link=$(expr "$ls" : '.*-> \(.*\)$')
  if expr "$link" : '/.*' > /dev/null; then
    PRG=$link
  else
    PRG=$(dirname "$PRG")"/$link"
  fi
done
SAVED="$(cd "$(dirname "$PRG")" >/dev/null 2>&1 && pwd)"
SCRIPT_DIR="$(cd "$(dirname "$PRG")" >/dev/null 2>&1 && pwd)"

# When using Cygwin, switch paths to Windows format before running java
if [ "$CYGWIN" = "true" -o "$MSYS" = "true" ]; then
  APP_HOME=$(cygpath --path --mixed "$APP_HOME")
  CLASSPATH=$(cygpath --path --mixed "$CLASSPATH")
  JAVACMD=$(cygpath --url "$JAVACMD")
  for i in "${app_classpath[@]}"; do
    app_classpath_converted+=("$(cygpath --path --mixed "$i")")
  done
  CLASSPATH=$(printf '%s' "${app_classpath_converted[@]}" | tr ':' ';')
fi

APP_HOME=$SCRIPT_DIR
CLASSPATH=$APP_HOME/gradle/wrapper/gradle-wrapper.jar

# Determine the Java command to use to start the JVM.
if [ ! -z "$JAVA_HOME" ]; then
  if [ -x "$JAVA_HOME/jre/sh/java" ]; then
    JAVACMD=$JAVA_HOME/jre/sh/java
  else
    JAVACMD=$JAVA_HOME/bin/java
  fi
  if [ ! -x "$JAVACMD" ]; then
    echo "error: JAVA_HOME is set to invalid location \"$JAVA_HOME\"" >&2
    exit 1
  fi
else
  JAVACMD=java
  if ! command -v java >/dev/null 2>&1; then
    echo "error: JAVA_HOME is not set and no 'java' command could be found in your PATH." >&2
    exit 1
  fi
fi

# Increase the maximum file descriptors if we can.
if ! "$cygwin" && ! "$msys" && ! "$darwin"; then
  case $( (ulimit -H -n) 2>/dev/null) in #(
    (unlimited|(2)[15][0-9][0-9][0-9][0-9][0-9][0-9]*)
      ulimit -n 200000 ;;
  esac
fi

# Collect all arguments for the java command, stacking in reverse order:
#   * args from the command line
#   * the main class name
#   * -classpath
#   * -D...appname settings
#   * --module-path
#   * the jvm arguments

# For Cygwin or MSYS, switch paths to Windows format before running java
if "$cygwin" || "$msys"; then
  APP_HOME=$( cygpath --path --mixed "$APP_HOME" )
  CLASSPATH=$( cygpath --path --mixed "$CLASSPATH" )
  JAVACMD=$( cygpath --url "$JAVACMD" )
  for i in "${app_classpath[@]}"; do
    app_classpath_converted+=("$(cygpath --path --mixed "$i")")
  done
  CLASSPATH=$(printf '%s' "${app_classpath_converted[@]}" | tr ':' ';')
fi

# We build the pattern for arguments to be converted via cygpath
ROOTDIRSRAW=$(find -L / -maxdepth 3 -type d -name java_modules 2>/dev/null)
for dir in $ROOTDIRSRAW ; do
  JAVA_MODULES="$( cygpath --path --ignore --mixed "$dir" )"
  CLASSPATH="$CLASSPATH:$JAVA_MODULES"
done

if [ -n "$JAVA_MODULES" ]; then
  JAVA_ARGS="$JAVA_ARGS --module-path $JAVA_MODULES"
fi

CLASSPATH=$( cygpath --path --ignore --mixed "$CLASSPATH" )

# Split up the JVM_OPTS And GRADLE_OPTS values into an array, following the shell quoting and substitution rules
function splitjvmargs() {
  local jvmargs=()
  while IFS= read -r arg; do
    jvmargs+=("$arg")
  done <<<"$1"
  for arg in "${jvmargs[@]}"; do
    echo "$arg"
  done
}
eval splitjvmargs $DEFAULT_JVM_OPTS $JAVA_OPTS $GRADLE_OPTS
JVM_OPTS=$(echo "$DEFAULT_JVM_OPTS $JAVA_OPTS $GRADLE_OPTS" | xargs)

exec "$JAVACMD" \
  $JVM_OPTS \
  -classpath "$CLASSPATH" \
  org.gradle.wrapper.GradleWrapperMain \
  "$@"
